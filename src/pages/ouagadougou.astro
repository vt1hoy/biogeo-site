---
import SiteLayout2 from "../layouts/SiteLayout2.astro";

const pageTranslations = {
  ru: {
    title: "Уагадугу — сельское хозяйство",
    subtitle:
      "Пилотная GIS-модель agricultural suitability для Centre, Burkina Faso на основе NDVI, NDWI, дорожной доступности и классификации пригодности."
  },
  en: {
    title: "Ouagadougou — agriculture",
    subtitle:
      "Pilot GIS model of agricultural suitability for Centre, Burkina Faso based on NDVI, NDWI, road accessibility and suitability classification."
  },
  fr: {
    title: "Ouagadougou — agriculture",
    subtitle:
      "Modèle SIG pilote de convenance agricole pour le Centre, Burkina Faso, basé sur le NDVI, le NDWI, l’accessibilité routière et la classification de convenance."
  }
};

const images = [
  {
    src: "/assets/ouagadougou/images/cellid.png"
  },
  {
    src: "/assets/ouagadougou/images/cellid2.png"
  }
];

const pdfs = [
  {
    file: "/assets/ouagadougou/pdf/Agrimod.pdf"
  }
];

const pipelineScripts = [
  {
    name: "1. Load_roads.py",
    file: "/assets/ouagadougou/code/load_roads.py"
  },
  {
    name: "2. Distance_raster.py",
    file: "/assets/ouagadougou/code/distance_raster.py"
  },
  {
    name: "3. Lign_rasters.py",
    file: "/assets/ouagadougou/code/align_rasters.py"
  },
  {
    name: "4. Agri_model.py",
    file: "/assets/ouagadougou/code/agri_model.py"
  }
];

const translations = {
  ru: {
    caseLabel: "Кейс",
    caseIntro:
      "Этот кейс представляет пилотную spatial model сельскохозяйственной пригодности для региона Centre-Ouest в Burkina Faso. Модель собирает в один suitability index состояние растительности, moisture availability и proximity to roads, чтобы показать, где agricultural potential относительно выше, а где он ограничен.",
    caseResultsTitle: "Что получилось",
    caseResults: [
      "Высокая пригодность в основном проявляется в peri-urban и rural зонах, где растительность выражена сильнее, а фрагментация землепользования ниже.",
      "Низкая пригодность концентрируется в urban core Ouagadougou, где vegetation cover слабее и land use более интенсивен.",
      "Дороги улучшают accessibility, но не компенсируют экологические ограничения в плотно застроенных участках.",
      "Итоговая карта показывает переход от менее пригодного центра к более перспективным окружающим территориям."
    ],
    maps: "Карты",
    pdf: "PDF",
    workflow: "QGIS workflow",
    python: "Python / GeoPandas",
    pipeline: "Full pipeline",
    pipelineSubtitle: "Полная последовательность скриптов по кейсу",
    pdfOpen: "Открыть PDF",
    fileOpen: "Открыть файл",
    scriptOpen: "Скачать / открыть",
    copy: "Копировать",
    copied: "Скопировано",
    imageTitles: [
      "Agricultural suitability map",
      "Suitability classification and road accessibility"
    ],
    pdfTitles: [
      "Agricultural Suitability Model — Field Brief"
    ],
    workflowItems: [
      {
        title: "Workflow 1 — подготовка данных",
        steps: [
          "Мозаика сцен Landsat 8",
          "Перепроецирование в EPSG:4326",
          "Обрезка всех слоёв по границе GADM",
          "Подготовка NDVI и NDWI",
          "Выравнивание растровой сетки и разрешения"
        ]
      },
      {
        title: "Workflow 2 — модель пригодности",
        steps: [
          "Извлечение дорожной сети OSM",
          "Растеризация дорог и построение distance raster",
          "Нормализация и инверсия accessibility",
          "Объединение NDVI, NDWI и Access",
          "Классификация на low / medium / high"
        ]
      }
    ],
    codeTitle1: "Python — preprocessing and alignment",
    codeTitle2: "Python — suitability model",
    codeDesc1:
      "Подготовка границы, дорог и спутниковых слоёв, alignment raster grid и проверка spatial consistency.",
    codeDesc2:
      "Расчёт NDVI / NDWI, distance raster, accessibility layer, composite suitability score и финальной классификации.",
    codeLoadError: "Ошибка загрузки кода"
  },

  en: {
    caseLabel: "Case",
    caseIntro:
      "This case presents a pilot spatial model of agricultural suitability for the Centre-Ouest region of Burkina Faso. The model integrates vegetation condition, moisture availability and proximity to roads into a single suitability index in order to highlight where agricultural potential is relatively higher and where it remains constrained.",
    caseResultsTitle: "Key results",
    caseResults: [
      "Higher suitability is mainly concentrated in peri-urban and rural zones where vegetation conditions are stronger and land fragmentation is lower.",
      "Lower suitability is concentrated in the urban core of Ouagadougou, where vegetation cover is weaker and land use is more intensive.",
      "Road infrastructure improves accessibility but does not compensate for environmental limitations in densely built-up areas.",
      "The final map reveals a transition from lower suitability in the urban center to more favorable surrounding areas."
    ],
    maps: "Maps",
    pdf: "PDF",
    workflow: "QGIS workflow",
    python: "Python / GeoPandas",
    pipeline: "Full pipeline",
    pipelineSubtitle: "Complete script sequence used in this case",
    pdfOpen: "Open PDF",
    fileOpen: "Open file",
    scriptOpen: "Download / open",
    copy: "Copy",
    copied: "Copied",
    imageTitles: [
      "Agricultural suitability map",
      "Suitability classification and road accessibility"
    ],
    pdfTitles: [
      "Agricultural Suitability Model — Field Brief"
    ],
    workflowItems: [
      {
        title: "Workflow 1 — data preparation",
        steps: [
          "Mosaic Landsat 8 scenes",
          "Reproject to EPSG:4326",
          "Clip all layers to GADM boundary",
          "Prepare NDVI and NDWI",
          "Align raster grid and resolution"
        ]
      },
      {
        title: "Workflow 2 — suitability model",
        steps: [
          "Extract OSM road network",
          "Rasterize roads and build distance raster",
          "Normalize and invert accessibility",
          "Combine NDVI, NDWI and Access",
          "Classify into low / medium / high"
        ]
      }
    ],
    codeTitle1: "Python — preprocessing and alignment",
    codeTitle2: "Python — suitability model",
    codeDesc1:
      "Preparation of the boundary, roads and satellite layers, raster alignment and spatial consistency checks.",
    codeDesc2:
      "Calculation of NDVI / NDWI, distance raster, accessibility layer, composite suitability score and final classification.",
    codeLoadError: "Code loading error"
  },

  fr: {
    caseLabel: "Cas",
    caseIntro:
      "Ce cas présente un modèle spatial pilote de convenance agricole pour la région du Centre-Ouest au Burkina Faso. Le modèle réunit l’état de la végétation, la disponibilité en eau et la proximité au réseau routier dans un indice unique de convenance afin de montrer où le potentiel agricole est relativement plus élevé et où il reste limité.",
    caseResultsTitle: "Résultats clés",
    caseResults: [
      "Les zones de forte convenance se concentrent surtout dans les espaces périurbains et ruraux où la végétation est plus forte et la fragmentation du sol plus faible.",
      "Les zones de faible convenance correspondent au noyau urbain de Ouagadougou, où la couverture végétale est réduite et l’usage du sol plus intensif.",
      "Le réseau routier améliore l’accessibilité mais ne compense pas les limites environnementales dans les espaces densément bâtis.",
      "La carte finale montre une transition du centre urbain moins favorable vers des espaces périphériques plus prometteurs."
    ],
    maps: "Cartes",
    pdf: "PDF",
    workflow: "QGIS workflow",
    python: "Python / GeoPandas",
    pipeline: "Full pipeline",
    pipelineSubtitle: "Séquence complète des scripts utilisés dans ce cas",
    pdfOpen: "Ouvrir le PDF",
    fileOpen: "Ouvrir le fichier",
    scriptOpen: "Télécharger / ouvrir",
    copy: "Copier",
    copied: "Copié",
    imageTitles: [
      "Carte de convenance agricole",
      "Classification de convenance et accessibilité routière"
    ],
    pdfTitles: [
      "Agricultural Suitability Model — Field Brief"
    ],
    workflowItems: [
      {
        title: "Workflow 1 — préparation des données",
        steps: [
          "Mosaïque des scènes Landsat 8",
          "Reprojection en EPSG:4326",
          "Découpage de toutes les couches sur la limite GADM",
          "Préparation de NDVI et NDWI",
          "Alignement de la grille raster et de la résolution"
        ]
      },
      {
        title: "Workflow 2 — modèle de convenance",
        steps: [
          "Extraction du réseau routier OSM",
          "Rasterisation des routes et construction du raster de distance",
          "Normalisation et inversion de l’accessibilité",
          "Combinaison de NDVI, NDWI et Access",
          "Classification en low / medium / high"
        ]
      }
    ],
    codeTitle1: "Python — prétraitement et alignement",
    codeTitle2: "Python — modèle de convenance",
    codeDesc1:
      "Préparation de la limite, des routes et des couches satellites, alignement raster et contrôle de cohérence spatiale.",
    codeDesc2:
      "Calcul de NDVI / NDWI, distance raster, couche d’accessibilité, score composite et classification finale.",
    codeLoadError: "Erreur de chargement du code"
  }
};
---

<SiteLayout2 pageTranslations={pageTranslations}>
  <style>
    .block {
      background: rgba(255, 255, 255, 0.96);
      padding: 24px;
      border-radius: 18px;
      margin-bottom: 20px;
      border: 1px solid #d9e1ea;
      box-shadow: 0 8px 20px rgba(40, 60, 90, 0.05);
    }

    .block h2 {
      margin-top: 0;
      margin-bottom: 14px;
      color: #1d3d67;
      font-size: 28px;
      letter-spacing: -0.02em;
    }

    .case-text {
      margin: 0;
      color: #425b78;
      line-height: 1.75;
      font-size: 15px;
      max-width: 980px;
    }

    .case-subtitle {
      margin: 18px 0 10px;
      font-size: 22px;
      line-height: 1.1;
      color: #1d3d67;
      letter-spacing: -0.02em;
    }

    .case-list {
      margin: 0;
      padding-left: 18px;
      color: #425b78;
      line-height: 1.75;
      font-size: 15px;
    }

    .image-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
    }

    .image-card {
      background: #fff;
      border: 1px solid #dde5ed;
      border-radius: 14px;
      overflow: hidden;
    }

    .image-card img {
      width: 100%;
      display: block;
      aspect-ratio: 16 / 10;
      object-fit: cover;
    }

    .image-caption {
      padding: 12px 14px;
      font-size: 14px;
      color: #5d6f86;
    }

    .image-caption a {
      color: #174b87;
      font-weight: 600;
    }

    .pdf-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
    }

    .pdf-card,
    .pipeline-card {
      background: #fbfdff;
      border: 1px solid #e1e8f0;
      border-radius: 14px;
      padding: 18px;
    }

    .pdf-card h3,
    .pipeline-card h3 {
      margin: 0 0 10px;
      color: #284a73;
      font-size: 18px;
    }

    .pdf-card a,
    .pipeline-card a {
      color: #174b87;
      font-weight: 600;
      font-size: 14px;
    }

    .workflow-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
    }

    .workflow-item {
      background: #fbfdff;
      border: 1px solid #e1e8f0;
      border-radius: 14px;
      padding: 18px;
    }

    .workflow-item h3 {
      margin: 0 0 10px;
      color: #284a73;
      font-size: 18px;
    }

    .workflow-item ul {
      margin: 0;
      padding-left: 18px;
      line-height: 1.7;
      color: #425b78;
      font-size: 15px;
    }

    .pipeline-top {
      margin-bottom: 16px;
      color: #5d6f86;
      font-size: 15px;
      line-height: 1.6;
    }

    .pipeline-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
    }

    .script-name {
      margin: 0 0 10px;
      font-size: 16px;
      font-weight: 700;
      color: #1d3d67;
      font-family: Consolas, monospace;
    }

    .code-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 18px;
    }

    .code-card {
      background: #fbfdff;
      border: 1px solid #e1e8f0;
      border-radius: 14px;
      padding: 18px;
    }

    .code-card h3 {
      margin: 0 0 10px;
      color: #284a73;
    }

    .code-description {
      margin-bottom: 12px;
      color: #5b6d85;
      font-size: 14px;
      line-height: 1.6;
    }

    .code-top {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
      margin-bottom: 10px;
      flex-wrap: wrap;
    }

    .code-top a {
      color: #174b87;
      font-weight: 600;
      font-size: 14px;
    }

    .btn {
      background: #174b87;
      color: white;
      border: none;
      padding: 8px 14px;
      border-radius: 8px;
      cursor: pointer;
      font-size: 14px;
    }

    .btn:hover {
      opacity: 0.92;
    }

    .code-block {
      background: #0f1722;
      color: #d9e7ff;
      padding: 16px;
      border-radius: 12px;
      font-family: Consolas, monospace;
      white-space: pre-wrap;
      overflow-wrap: anywhere;
      word-break: break-word;
      overflow-x: auto;
      overflow-y: auto;
      line-height: 1.55;
      max-height: 420px;
      font-size: 13px;
      box-shadow: inset 0 0 0 1px rgba(255,255,255,0.04);
    }

    .code-card,
    .code-block,
    .pipeline-card,
    .workflow-item,
    .pdf-card,
    .image-card {
      min-width: 0;
    }

    .code-card h3,
    .code-description,
    .code-top a,
    .pipeline-card h3,
    .image-caption a,
    .pdf-card h3,
    .workflow-item h3,
    .script-name,
    .block p,
    .block li {
      overflow-wrap: anywhere;
      word-break: break-word;
    }

    @media (max-width: 900px) {
      .image-grid,
      .pdf-grid,
      .workflow-grid,
      .pipeline-grid {
        grid-template-columns: 1fr;
      }
    }

    @media (max-width: 640px) {
      .block {
        padding: 16px;
        border-radius: 14px;
      }

      .block h2 {
        font-size: 22px;
        line-height: 1.2;
      }

      .case-subtitle,
      .code-card h3,
      .pipeline-card h3,
      .workflow-item h3,
      .pdf-card h3 {
        font-size: 17px;
        line-height: 1.3;
      }

      .code-card,
      .pipeline-card,
      .workflow-item,
      .pdf-card {
        padding: 16px;
        border-radius: 12px;
      }

      .code-top {
        align-items: stretch;
      }

      .btn {
        width: 100%;
      }

      .code-block {
        font-size: 11px;
        padding: 12px;
      }
    }
  </style>

  <div class="block">
    <h2 id="case-heading">{translations.ru.caseLabel}</h2>
    <p class="case-text" id="case-intro">{translations.ru.caseIntro}</p>

    <h3 class="case-subtitle" id="case-results-title">{translations.ru.caseResultsTitle}</h3>
    <ul class="case-list">
      {translations.ru.caseResults.map((item, index) => (
        <li id={`case-result-${index}`}>{item}</li>
      ))}
    </ul>
  </div>

  <div class="block">
    <h2 id="maps-heading">{translations.ru.maps}</h2>

    <div class="image-grid">
      {images.map((item, index) => (
        <div class="image-card">
          <a href={item.src} target="_blank">
            <img src={item.src} alt={`ouagadougou-image-${index + 1}`} />
          </a>
          <div class="image-caption">
            <a href={item.src} target="_blank" id={`image-title-${index}`}>
              {translations.ru.imageTitles[index]}
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>

  <div class="block">
    <h2 id="pdf-heading">{translations.ru.pdf}</h2>

    <div class="pdf-grid">
      {pdfs.map((pdf, index) => (
        <div class="pdf-card">
          <h3 id={`pdf-title-${index}`}>{translations.ru.pdfTitles[index]}</h3>
          <a href={pdf.file} target="_blank" class="pdf-open">
            {translations.ru.pdfOpen}
          </a>
        </div>
      ))}
    </div>
  </div>

  <div class="block">
    <h2 id="workflow-heading">{translations.ru.workflow}</h2>

    <div class="workflow-grid">
      {translations.ru.workflowItems.map((wf, wfIndex) => (
        <div class="workflow-item">
          <h3 id={`workflow-title-${wfIndex}`}>{wf.title}</h3>
          <ul id={`workflow-steps-${wfIndex}`}>
            {wf.steps.map((step) => (
              <li>{step}</li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>

  <div class="block">
    <h2 id="python-heading">{translations.ru.python}</h2>

    <div class="code-grid">
      <div class="code-card">
        <h3 id="code-title-1">{translations.ru.codeTitle1}</h3>

        <div class="code-description" id="code-desc-1">
          {translations.ru.codeDesc1}
        </div>

        <div class="code-top">
          <a href="/assets/ouagadougou/code/analysis.py" target="_blank" class="code-open">
            {translations.ru.fileOpen}
          </a>
          <button class="btn copy-btn" onclick="copyCode('code1', this)">
            {translations.ru.copy}
          </button>
        </div>

        <pre class="code-block" id="code1">Загрузка...</pre>
      </div>

      <div class="code-card">
        <h3 id="code-title-2">{translations.ru.codeTitle2}</h3>

        <div class="code-description" id="code-desc-2">
          {translations.ru.codeDesc2}
        </div>

        <div class="code-top">
          <a href="/assets/ouagadougou/code/analysis2.py" target="_blank" class="code-open">
            {translations.ru.fileOpen}
          </a>
          <button class="btn copy-btn" onclick="copyCode('code2', this)">
            {translations.ru.copy}
          </button>
        </div>

        <pre class="code-block" id="code2">Загрузка...</pre>
      </div>
    </div>
  </div>

  <div class="block">
    <h2 id="pipeline-heading">{translations.ru.pipeline}</h2>
    <div class="pipeline-top" id="pipeline-subtitle">{translations.ru.pipelineSubtitle}</div>

    <div class="pipeline-grid">
      {pipelineScripts.map((script, index) => (
        <div class="pipeline-card">
          <p class="script-name">{script.name}</p>
          <a href={script.file} target="_blank" class="script-open" id={`script-open-${index}`}>
            {translations.ru.scriptOpen}
          </a>
        </div>
      ))}
    </div>
  </div>

  <script define:vars={{ translations }}>
    const i18n = translations;

    function renderWorkflowItems(t) {
      t.workflowItems.forEach((wf, wfIndex) => {
        const titleEl = document.getElementById(`workflow-title-${wfIndex}`);
        const stepsEl = document.getElementById(`workflow-steps-${wfIndex}`);

        if (titleEl) titleEl.textContent = wf.title;

        if (stepsEl) {
          stepsEl.innerHTML = "";
          wf.steps.forEach((step) => {
            const li = document.createElement("li");
            li.textContent = step;
            stepsEl.appendChild(li);
          });
        }
      });
    }

    function setOuagaLang(lang) {
      const t = i18n[lang];
      if (!t) return;

      document.getElementById("case-heading").textContent = t.caseLabel;
      document.getElementById("case-intro").textContent = t.caseIntro;
      document.getElementById("case-results-title").textContent = t.caseResultsTitle;

      t.caseResults.forEach((item, index) => {
        const el = document.getElementById(`case-result-${index}`);
        if (el) el.textContent = item;
      });

      document.getElementById("maps-heading").textContent = t.maps;
      document.getElementById("pdf-heading").textContent = t.pdf;
      document.getElementById("workflow-heading").textContent = t.workflow;
      document.getElementById("python-heading").textContent = t.python;
      document.getElementById("pipeline-heading").textContent = t.pipeline;
      document.getElementById("pipeline-subtitle").textContent = t.pipelineSubtitle;

      t.imageTitles.forEach((title, index) => {
        const el = document.getElementById(`image-title-${index}`);
        if (el) el.textContent = title;
      });

      t.pdfTitles.forEach((title, index) => {
        const el = document.getElementById(`pdf-title-${index}`);
        if (el) el.textContent = title;
      });

      renderWorkflowItems(t);

      document.getElementById("code-title-1").textContent = t.codeTitle1;
      document.getElementById("code-title-2").textContent = t.codeTitle2;
      document.getElementById("code-desc-1").textContent = t.codeDesc1;
      document.getElementById("code-desc-2").textContent = t.codeDesc2;

      document.querySelectorAll(".pdf-open").forEach((el) => {
        el.textContent = t.pdfOpen;
      });

      document.querySelectorAll(".script-open").forEach((el) => {
        el.textContent = t.scriptOpen;
      });

      document.querySelectorAll(".code-open").forEach((el) => {
        el.textContent = t.fileOpen;
      });

      document.querySelectorAll(".copy-btn").forEach((el) => {
        el.textContent = t.copy;
        el.dataset.copyLabel = t.copy;
        el.dataset.copiedLabel = t.copied;
      });
    }

    async function loadCode(id, path) {
      const el = document.getElementById(id);
      try {
        const res = await fetch(path);
        if (!res.ok) throw new Error("fetch failed");
        const text = await res.text();
        el.textContent = text;
      } catch {
        const savedLang = localStorage.getItem("lang") || "ru";
        el.textContent = i18n[savedLang].codeLoadError;
      }
    }

    window.copyCode = function (id, btn) {
      const text = document.getElementById(id).textContent;
      navigator.clipboard.writeText(text);

      const copiedLabel = btn.dataset.copiedLabel || "Скопировано";
      const copyLabel = btn.dataset.copyLabel || "Копировать";

      btn.textContent = copiedLabel;
      setTimeout(() => {
        btn.textContent = copyLabel;
      }, 1200);
    };

    const savedLang = localStorage.getItem("lang") || "ru";
    setOuagaLang(savedLang);

    window.addEventListener("languageChanged", (event) => {
      setOuagaLang(event.detail.lang);
    });

    loadCode("code1", "/assets/ouagadougou/code/analysis.py");
    loadCode("code2", "/assets/ouagadougou/code/analysis2.py");
  </script>
</SiteLayout2>