---
import SiteLayout2 from "../layouts/SiteLayout2.astro";

const pageTranslations = {
  ru: {
    title: "Ниамей - риск затопления",
    subtitle:
      "Пилотный GIS-кейс по анализу риска затопления в Ниамее на основе цифровой модели рельефа (Copernicus DEM): уклон, накопление стока и индекс риска (flow accumulation + slope) для выявления структуры дренажной сети и потенциальных зон подтопления."
  },
  en: {
    title: "Niamey — flood risk",
    subtitle:
      "Pilot GIS case on flood risk analysis in Niamey based on a digital elevation model (Copernicus DEM): slope, flow accumulation and a composite risk index to reveal drainage structure and potential flood-prone areas."
  },
  fr: {
    title: "Niamey — risque d’inondation",
    subtitle:
      "Cas SIG pilote d’analyse du risque d’inondation à Niamey basé sur un modèle numérique de terrain (Copernicus DEM) : pente, accumulation de flux et indice de risque pour identifier la structure du drainage et les zones potentiellement inondables."
  }
};

const images = [
  {
    src: "/assets/niamey/images/flood_risk_index.png"
  },
  {
    src: "/assets/niamey/images/ndwi.png"
  }
];

const pdfs = [
  {
    file: "/assets/niamey/pdf/brief_niamey2.pdf"
  }
];

const pipelineScripts = [
  {
    name: "1. niamey_dem_preprocess.py",
    file: "/assets/niamey/code/niamey_dem_preprocess.py"
  },
  {
    name: "2. slope.py",
    file: "/assets/niamey/code/niamey_slope.py"
  },
  {
    name: "3. flow_accumulation.py",
    file: "/assets/niamey/code/niamey_flow.py"
  },
  {
    name: "4. flood_risk_index.py",
    file: "/assets/niamey/code/niamey_index.py"
  }
];

const translations = {
  ru: {
    caseLabel: "Кейс",
    caseIntro:
      "Этот кейс представляет пилотный spatial analysis риска затопления в Ниамее на основе цифровой модели рельефа (Copernicus DEM). Анализ включает расчёт уклона, накопления стока (flow accumulation) и построение индекса риска, чтобы выявить структуру дренажной сети и потенциальные зоны подтопления.",
