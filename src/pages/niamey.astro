          "Расчёт уклона (slope)",
          "Логарифмирование flow accumulation (log10)",
          "Нормализация показателей (flow и slope)",
          "Расчёт интегрального индекса риска",
          "Визуализация и оформление карты"
        ]
      }
    ],
    codeTitle1: "numpy - slope",
    codeTitle2: "whitebox — flow accumulation",
    codeDesc1:
      "Расчёт уклона рельефа на основе DEM с использованием градиентов по осям X и Y.",
    codeDesc2:
      "Расчёт накопления стока (D8) на основе DEM, показывающий количество ячеек, дренирующихся в каждую точку"
  },

  en: {
    caseLabel: "Case",
    caseIntro:
      "This case presents a pilot spatial analysis of flood risk in Niamey based on a digital elevation model (Copernicus DEM). The analysis includes slope calculation, flow accumulation, and a composite risk index to identify drainage structure and potential flood-prone areas.",
    caseResultsTitle: "Key results",
    caseResults: [
      "A detailed drainage network structure derived from terrain has been identified.",
      "The Niger River clearly stands out as the main high flow accumulation corridor.",
      "Secondary and local channels forming potential water pathways have been detected.",
      "Areas with high flood risk outside existing water bodies have been identified.",
      "The final model represents spatial flood susceptibility across the territory."
    ],
    maps: "Maps",
    pdf: "PDF",
    workflow: "Workflow",
    python: "Python / numpy / whitebox",
    pipeline: "Full pipeline",
    pipelineSubtitle: "Complete script sequence used in this case",
    pdfOpen: "Open PDF",
    fileOpen: "Open file",
    scriptOpen: "Download / open",
    copy: "Copy",
    copied: "Copied",
    imageTitles: [
      "flood risk index",
      "ndwi"
    ],
    pdfTitles: [
      "GIS Analysis Brief"
    ],
    workflowItems: [
      {
        title: "Workflow 1 — data preparation",
        steps: [
          "Load Copernicus DEM and clip to Niamey boundary",
          "Reproject to UTM 28N (EPSG:32628)",
          "Prepare elevation raster (DEM)",
          "Validate spatial consistency"
        ]
      },
      {
        title: "Workflow 2 — spatial analysis",
        steps: [
          "Fill depressions in DEM (FillDepressions)",
          "Compute flow accumulation (D8)",
          "Calculate slope",
          "Apply log transformation to flow accumulation (log10)",
          "Normalize variables (flow and slope)",
          "Compute composite flood risk index",
          "Map visualization and styling"
        ]
      }
    ],
    codeTitle1: "numpy — slope",
    codeTitle2: "whitebox - flow accumulation",
    codeDesc1:
      "Slope calculated from DEM using spatial gradients along X and Y directions",
    codeDesc2:
      "D8 flow accumulation computed from DEM, representing the number of upstream cells draining into each pixel"
  },

  fr: {
    caseLabel: "Cas",
    caseIntro:
      "Ce cas présente une analyse spatiale pilote du risque d’inondation à Niamey basée sur un modèle numérique de terrain (Copernicus DEM). L’analyse inclut le calcul de la pente, de l’accumulation des flux et la construction d’un indice de risque afin d’identifier la structure de drainage et les zones potentiellement inondables.",
    caseResultsTitle: "Résultats clés",
    caseResults: [
      "Une structure détaillée du réseau de drainage dérivée du relief a été identifiée.",
      "Le fleuve Niger apparaît clairement comme le principal corridor d’accumulation des flux.",
      "Des canaux secondaires et locaux formant des voies potentielles d’écoulement ont été détectés.",
      "Des zones à fort risque d’inondation en dehors des cours d’eau actuels ont été identifiées.",
      "Le modèle final représente la susceptibilité spatiale aux inondations du territoire."
    ],
    maps: "Cartes",
    pdf: "PDF",
    workflow: "Workflow",
    python: "Python / numpy / whitebox",
    pipeline: "Full pipeline",
    pipelineSubtitle: "Séquence complète des scripts utilisés dans ce cas",
    pdfOpen: "Ouvrir le PDF",
    fileOpen: "Ouvrir le fichier",
    scriptOpen: "Télécharger / ouvrir",
    copy: "Copier",
    copied: "Copié",
    imageTitles: [
      "flood risk index",
      "ndwi"
    ],
    pdfTitles: [
      "Note d’analyse SIG"
    ],
    workflowItems: [
      {
        title: "Workflow 1 — préparation des données",
        steps: [
          "Chargement du DEM Copernicus et découpage selon la zone de Niamey",
          "Reprojection en UTM 28N (EPSG:32628)",
          "Préparation du raster d’élévation (DEM)",
          "Vérification de la cohérence spatiale"
        ]
      },
      {
        title: "Workflow 2 — analyse spatiale",
        steps: [
          "Remplissage des dépressions (FillDepressions)",
          "Calcul de l’accumulation des flux (D8)",
          "Calcul de la pente",
          "Transformation logarithmique du flow accumulation (log10)",
          "Normalisation des variables (flow et pente)",
          "Calcul de l’indice de risque",
          "Visualisation et mise en forme de la carte"
        ]
      }
    ],
    codeTitle1: "numpy — slope",
    codeTitle2: "whitebox — flow accumulation",
    codeDesc1:
      "Pente calculée à partir du DEM en utilisant les gradients spatiaux selon les axes X et Y",
    codeDesc2:
      "Accumulation des flux (D8) calculée à partir du DEM, représentant le nombre de cellules en amont drainant vers chaque pixel"
  }
};
---

<SiteLayout2 pageTranslations={pageTranslations}>
  <style>
    .block {
      background: rgba(255, 255, 255, 0.96);
      padding: 24px;
      border-radius: 18px;
      margin-bottom: 20px;
      border: 1px solid #d9e1ea;
      box-shadow: 0 8px 20px rgba(40, 60, 90, 0.05);
    }

    .block h2 {
      margin-top: 0;
      margin-bottom: 14px;
      color: #1d3d67;
      font-size: 28px;
      letter-spacing: -0.02em;
    }

    .case-text {
      margin: 0;
      color: #425b78;
      line-height: 1.75;
      font-size: 15px;
      max-width: 980px;
    }

    .case-subtitle {
      margin: 18px 0 10px;
      font-size: 22px;
      line-height: 1.1;
      color: #1d3d67;
      letter-spacing: -0.02em;
    }

    .case-list {
      margin: 0;
      padding-left: 18px;
      color: #425b78;
      line-height: 1.75;
      font-size: 15px;
    }

    .image-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
    }

    .image-card {
      background: #fff;
      border: 1px solid #dde5ed;
      border-radius: 14px;
      overflow: hidden;
    }

    .image-card img {
      width: 100%;
      display: block;
      aspect-ratio: 16 / 10;
      object-fit: cover;
    }

    .image-caption {
      padding: 12px 14px;
      font-size: 14px;
      color: #5d6f86;
    }

    .image-caption a {
      color: #174b87;
      font-weight: 600;
    }

    .pdf-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
    }

    .pdf-card,
    .pipeline-card {
      background: #fbfdff;
      border: 1px solid #e1e8f0;
      border-radius: 14px;
      padding: 18px;
    }

    .pdf-card h3,
    .pipeline-card h3 {
      margin: 0 0 10px;
      color: #284a73;
      font-size: 18px;
    }

    .pdf-card a,
    .pipeline-card a {
      color: #174b87;
      font-weight: 600;
      font-size: 14px;
    }

    .workflow-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
    }

    .workflow-item {
      background: #fbfdff;
      border: 1px solid #e1e8f0;
      border-radius: 14px;
      padding: 18px;
    }

    .workflow-item h3 {
      margin: 0 0 10px;
      color: #284a73;
      font-size: 18px;
    }

    .workflow-item ul {
      margin: 0;
      padding-left: 18px;
      line-height: 1.7;
      color: #425b78;
      font-size: 15px;
    }

    .pipeline-top {
      margin-bottom: 16px;
      color: #5d6f86;
      font-size: 15px;
      line-height: 1.6;
    }

    .pipeline-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
    }

    .script-name {
      margin: 0 0 10px;
      font-size: 16px;
      font-weight: 700;
      color: #1d3d67;
      font-family: Consolas, monospace;
    }

    .code-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 18px;
    }

    .code-card {
      background: #fbfdff;
      border: 1px solid #e1e8f0;
      border-radius: 14px;
      padding: 18px;
    }

    .code-card h3 {
      margin: 0 0 10px;
      color: #284a73;
    }

    .code-description {
      margin-bottom: 12px;
      color: #5b6d85;
      font-size: 14px;
      line-height: 1.6;
    }

    .code-top {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
      margin-bottom: 10px;
      flex-wrap: wrap;
    }

    .code-top a {
      color: #174b87;
      font-weight: 600;
      font-size: 14px;
    }

    .btn {
      background: #174b87;
      color: white;
      border: none;
      padding: 8px 14px;
      border-radius: 8px;
      cursor: pointer;
      font-size: 14px;
    }

    .btn:hover {
      opacity: 0.92;
    }

    .code-block {
      background: #0f1722;
      color: #d9e7ff;
      padding: 16px;
      border-radius: 12px;
      font-family: Consolas, monospace;
      white-space: pre-wrap;
      overflow: auto;
      line-height: 1.55;
      max-height: 420px;
      font-size: 13px;
      box-shadow: inset 0 0 0 1px rgba(255,255,255,0.04);
    }

    @media (max-width: 900px) {
      .image-grid,
      .pdf-grid,
      .workflow-grid,
      .pipeline-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>

  <div class="block">
    <h2 id="case-heading">{translations.ru.caseLabel}</h2>
    <p class="case-text" id="case-intro">{translations.ru.caseIntro}</p>

    <h3 class="case-subtitle" id="case-results-title">{translations.ru.caseResultsTitle}</h3>
    <ul class="case-list">
      {translations.ru.caseResults.map((item, index) => (
        <li id={`case-result-${index}`}>{item}</li>
      ))}
    </ul>
  </div>

  <div class="block">
    <h2 id="maps-heading">{translations.ru.maps}</h2>

    <div class="image-grid">
      {images.map((item, index) => (
        <div class="image-card">
          <a href={item.src} target="_blank">
            <img src={item.src} alt={`ouagadougou-image-${index + 1}`} />
          </a>
          <div class="image-caption">
            <a href={item.src} target="_blank" id={`image-title-${index}`}>
              {translations.ru.imageTitles[index]}
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>

  <div class="block">
    <h2 id="pdf-heading">{translations.ru.pdf}</h2>

    <div class="pdf-grid">
      {pdfs.map((pdf, index) => (
        <div class="pdf-card">
          <h3 id={`pdf-title-${index}`}>{translations.ru.pdfTitles[index]}</h3>
          <a href={pdf.file} target="_blank" class="pdf-open">
            {translations.ru.pdfOpen}
          </a>
        </div>
      ))}
    </div>
  </div>

  <div class="block">
    <h2 id="workflow-heading">{translations.ru.workflow}</h2>

    <div class="workflow-grid">
      {translations.ru.workflowItems.map((wf, wfIndex) => (
        <div class="workflow-item">
          <h3 id={`workflow-title-${wfIndex}`}>{wf.title}</h3>
          <ul id={`workflow-steps-${wfIndex}`}>
            {wf.steps.map((step) => (
              <li>{step}</li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>

  <div class="block">
    <h2 id="python-heading">{translations.ru.python}</h2>

    <div class="code-grid">
      <div class="code-card">
        <h3 id="code-title-1">{translations.ru.codeTitle1}</h3>

        <div class="code-description" id="code-desc-1">
          {translations.ru.codeDesc1}
        </div>

        <div class="code-top">
          <a href="/assets/niamey/code/niamey_slope.py" target="_blank" class="code-open">
            {translations.ru.fileOpen}
          </a>
          <button class="btn copy-btn" onclick="copyCode('code1', this)">
            {translations.ru.copy}
          </button>
        </div>

        <pre class="code-block" id="code1">Загрузка...</pre>
      </div>

      <div class="code-card">
        <h3 id="code-title-2">{translations.ru.codeTitle2}</h3>

        <div class="code-description" id="code-desc-2">
          {translations.ru.codeDesc2}
        </div>

        <div class="code-top">
          <a href="/assets/niamey/code/niamey_flow.py" target="_blank" class="code-open">
            {translations.ru.fileOpen}
          </a>
          <button class="btn copy-btn" onclick="copyCode('code2', this)">
            {translations.ru.copy}
          </button>
        </div>

        <pre class="code-block" id="code2">Загрузка...</pre>
      </div>
    </div>
  </div>

  <div class="block">
    <h2 id="pipeline-heading">{translations.ru.pipeline}</h2>
    <div class="pipeline-top" id="pipeline-subtitle">{translations.ru.pipelineSubtitle}</div>

    <div class="pipeline-grid">
      {pipelineScripts.map((script, index) => (
        <div class="pipeline-card">
          <p class="script-name">{script.name}</p>
          <a href={script.file} target="_blank" class="script-open" id={`script-open-${index}`}>
            {translations.ru.scriptOpen}
          </a>
        </div>
      ))}
    </div>
  </div>

  <script define:vars={{ translations }}>
    const i18n = translations;

    function renderWorkflowItems(t) {
      t.workflowItems.forEach((wf, wfIndex) => {
        const titleEl = document.getElementById(`workflow-title-${wfIndex}`);
        const stepsEl = document.getElementById(`workflow-steps-${wfIndex}`);

        if (titleEl) titleEl.textContent = wf.title;

        if (stepsEl) {
          stepsEl.innerHTML = "";
          wf.steps.forEach((step) => {
            const li = document.createElement("li");
            li.textContent = step;
            stepsEl.appendChild(li);
          });
        }
      });
    }

    function setOuagaLang(lang) {
      const t = i18n[lang];
      if (!t) return;

      document.getElementById("case-heading").textContent = t.caseLabel;
      document.getElementById("case-intro").textContent = t.caseIntro;
      document.getElementById("case-results-title").textContent = t.caseResultsTitle;

      t.caseResults.forEach((item, index) => {
        const el = document.getElementById(`case-result-${index}`);
        if (el) el.textContent = item;
      });

      document.getElementById("maps-heading").textContent = t.maps;
      document.getElementById("pdf-heading").textContent = t.pdf;
      document.getElementById("workflow-heading").textContent = t.workflow;
      document.getElementById("python-heading").textContent = t.python;
      document.getElementById("pipeline-heading").textContent = t.pipeline;
      document.getElementById("pipeline-subtitle").textContent = t.pipelineSubtitle;

      t.imageTitles.forEach((title, index) => {
        const el = document.getElementById(`image-title-${index}`);
        if (el) el.textContent = title;
      });

      t.pdfTitles.forEach((title, index) => {
        const el = document.getElementById(`pdf-title-${index}`);
        if (el) el.textContent = title;
      });

      renderWorkflowItems(t);

      document.getElementById("code-title-1").textContent = t.codeTitle1;
      document.getElementById("code-title-2").textContent = t.codeTitle2;
      document.getElementById("code-desc-1").textContent = t.codeDesc1;
      document.getElementById("code-desc-2").textContent = t.codeDesc2;

      document.querySelectorAll(".pdf-open").forEach((el) => {
        el.textContent = t.pdfOpen;
      });

      document.querySelectorAll(".script-open").forEach((el) => {
        el.textContent = t.scriptOpen;
      });

      document.querySelectorAll(".code-open").forEach((el) => {
        el.textContent = t.fileOpen;
      });

      document.querySelectorAll(".copy-btn").forEach((el) => {
        el.textContent = t.copy;
        el.dataset.copyLabel = t.copy;
        el.dataset.copiedLabel = t.copied;
      });
    }

    async function loadCode(id, path) {
      const el = document.getElementById(id);
      try {
        const res = await fetch(path);
        if (!res.ok) throw new Error("fetch failed");
        const text = await res.text();
        el.textContent = text;
      } catch {
        const savedLang = localStorage.getItem("lang") || "ru";
        el.textContent = i18n[savedLang].codeLoadError;
      }
    }

    window.copyCode = function (id, btn) {
      const text = document.getElementById(id).textContent;
      navigator.clipboard.writeText(text);

      const copiedLabel = btn.dataset.copiedLabel || "Скопировано";
      const copyLabel = btn.dataset.copyLabel || "Копировать";

      btn.textContent = copiedLabel;
      setTimeout(() => {
        btn.textContent = copyLabel;
      }, 1200);
    };

    const savedLang = localStorage.getItem("lang") || "ru";
    setOuagaLang(savedLang);

    window.addEventListener("languageChanged", (event) => {
      setOuagaLang(event.detail.lang);
    });

    loadCode("code1", "/assets/niamey/code/niamey_slope.py");
    loadCode("code2", "/assets/niamey/code/niamey_flow.py");
  </script>
</SiteLayout2>