    img2: "Зоны хронического недоедания — Нигер. Региональная дифференциация продовольственной нестабильности, отражающая концентрацию кризисных территорий и приоритетные зоны вмешательства. Источник: WFP"
  },
  en: {
    title: "WFP — logistics and supply",
    place: "Dakar / Bamako / Niamey",
    type: "logistics / supply / access / routes",
    interest: "route analysis, accessibility, supply chains, distribution mapping",
    note: "GIS, QGIS, logistics understanding, data analysis, basic Python, English",
    img1: "Chronic malnutrition and AIC zones — Burkina Faso. Spatial distribution of vulnerability and food insecurity levels used for prioritizing humanitarian assistance. Source: WFP",
    img2: "Chronic malnutrition zones — Niger. Regional differentiation of food insecurity highlighting crisis areas and priority zones for intervention. Source: WFP"
  },
  fr: {
    title: "WFP — logistique et approvisionnement",
    place: "Dakar / Bamako / Niamey",
    type: "logistique / supply / accès / routes",
    interest: "analyse des routes, accessibilité, supply chains, distribution",
    note: "SIG, QGIS, compréhension logistique, analyse de données, Python de base, anglais",
    img1: "Malnutrition chronique et zones AIC — Burkina Faso. Répartition spatiale de la vulnérabilité et des niveaux d’insécurité alimentaire utilisée pour prioriser l’aide humanitaire. Source : WFP",
    img2: "Zones de malnutrition chronique — Niger. Différenciation régionale de l’insécurité alimentaire mettant en évidence les zones de crise et les priorités d’intervention. Source : WFP"
  },
  image1: "/assets/humanitarian/images/mission3a.png",
  image2: "/assets/humanitarian/images/mission3b.png"
  }
];
---

<SiteLayout pageTranslations={pageTranslations}>
  <style>
    .top-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 20px;
      margin-top: 24px;
      width: 100%;
      max-width: none;
    }

    .card {
      background: rgba(255, 255, 255, 0.96);
      border: 1px solid #d9e1ea;
      border-radius: 18px;
      padding: 22px;
      box-shadow: 0 8px 20px rgba(40, 60, 90, 0.05);
    }

    .card h2 {
      margin-top: 0;
      margin-bottom: 12px;
      color: #1d3d67;
    }

    .card p {
      margin: 0;
      line-height: 1.75;
      color: #425b78;
    }

    .missions-block {
      margin-top: 8px;
    }

    .missions-title {
      margin: 0 0 16px;
      color: #1d3d67;
      font-size: 28px;
    }

    .mission-card {
      background: rgba(255, 255, 255, 0.96);
      border: 1px solid #d9e1ea;
      border-radius: 18px;
      padding: 22px;
      box-shadow: 0 8px 20px rgba(40, 60, 90, 0.05);
      margin-bottom: 20px;
    }

    .mission-head {
      margin-bottom: 14px;
    }

    .mission-head h3 {
      margin: 0 0 8px;
      font-size: 24px;
      color: #1d3d67;
    }

    .mission-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 10px;
      margin-bottom: 14px;
    }

    .meta-pill {
      background: #eef4fb;
      color: #174b87;
      border: 1px solid #d7e2ef;
      border-radius: 999px;
      padding: 6px 12px;
      font-size: 13px;
      font-weight: 600;
    }

    .mission-text {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 18px;
      margin-bottom: 18px;
    }

    .mission-text-block {
      background: #fbfdff;
      border: 1px solid #e1e8f0;
      border-radius: 14px;
      padding: 16px;
    }

    .mission-text-block h4 {
      margin: 0 0 10px;
      color: #284a73;
      font-size: 16px;
    }

    .mission-text-block p {
      margin: 0;
      color: #425b78;
      line-height: 1.7;
    }

    .mission-gallery {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
    }

    .mission-image-card {
      background: white;
      border: 1px solid #dde5ed;
      border-radius: 16px;
      overflow: hidden;
    }

    .mission-image-card img {
      width: 100%;
      display: block;
      aspect-ratio: 16 / 10;
      object-fit: cover;
    }

    .mission-image-caption {
      padding: 12px 14px;
      font-size: 14px;
      color: #5d6f86;
    }

    @media (max-width: 980px) {
      .top-grid,
      .mission-text,
      .mission-gallery {
        grid-template-columns: 1fr;
      }
    }
  </style>

  <div class="top-grid">
    <div class="card">
      <h2 id="intro-title">{content.ru.introTitle}</h2>
      <p id="intro-text">{content.ru.introText}</p>
    </div>

  <div class="missions-block">
    <h2 class="missions-title" id="missions-title">{content.ru.missionTitle}</h2>

    {missions.map((mission) => (
      <div class="mission-card">
        <div class="mission-head">
          <h3 id={`${mission.key}-title`}>{mission.ru.title}</h3>
        </div>

        <div class="mission-meta">
          <div class="meta-pill" id={`${mission.key}-place`}>{mission.ru.place}</div>
          <div class="meta-pill" id={`${mission.key}-type`}>{mission.ru.type}</div>
        </div>

        <div class="mission-text">
          <div class="mission-text-block">
            <h4 id={`${mission.key}-keyTasks-title`}>{content.ru.keyTasks}</h4>
            <p id={`${mission.key}-interest`}>{mission.ru.interest}</p>
          </div>

          <div class="mission-text-block">
            <h4 id={`${mission.key}-requirements-title`}>{content.ru.requirementsTitle}</h4>
            <p id={`${mission.key}-requirements`}>{mission.ru.note}</p>
          </div>
        </div>

        <div class="mission-gallery">
          <div class="mission-image-card">
            <a href={mission.image1} target="_blank">
              <img src={mission.image1} alt={`${mission.key}-image-1`} />
            </a>
            <div class="mission-image-caption" id={`${mission.key}-img1`}>
              {content.ru.image1}
            </div>
          </div>

          <div class="mission-image-card">
            <a href={mission.image2} target="_blank">
              <img src={mission.image2} alt={`${mission.key}-image-2`} />
            </a>
            <div class="mission-image-caption" id={`${mission.key}-img2`}>
              {content.ru.image2}
            </div>
          </div>
          
        </div>
      </div>
    ))}
  </div>

  <script define:vars={{ content, missions }}>
    function setHumanitarianLang(lang) {
      const c = content[lang];
      if (!c) return;

      document.getElementById("intro-title").textContent = c.introTitle;
      document.getElementById("intro-text").textContent = c.introText;
      document.getElementById("missions-title").textContent = c.missionTitle;

      missions.forEach((mission) => {
        const t = mission[lang];
        if (!t) return;

        document.getElementById(`${mission.key}-title`).textContent = t.title;
        document.getElementById(`${mission.key}-place`).textContent = t.place;
        document.getElementById(`${mission.key}-type`).textContent = t.type;
        document.getElementById(`${mission.key}-interest`).textContent = t.interest;
        document.getElementById(`${mission.key}-requirements`).textContent = t.note;

        const keyTasksEl = document.getElementById(`${mission.key}-keyTasks-title`);
        if (keyTasksEl) keyTasksEl.textContent = c.keyTasks;

        const reqTitleEl = document.getElementById(`${mission.key}-requirements-title`);
        if (reqTitleEl) reqTitleEl.textContent = c.requirementsTitle;

        const img1 = document.getElementById(`${mission.key}-img1`);
        const img2 = document.getElementById(`${mission.key}-img2`);

        if (img1) img1.textContent = t.img1 || c.image1;
        if (img2) img2.textContent = t.img2 || c.image2;
      });
    }

    const savedLang = localStorage.getItem("lang") || "ru";
    setHumanitarianLang(savedLang);

    window.addEventListener("languageChanged", (event) => {
      setHumanitarianLang(event.detail.lang);
    });
  </script>

  </div> <!-- закрывает missions-block -->
  </div> <!-- закрывает top-grid -->
</SiteLayout>