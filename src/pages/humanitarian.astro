    },
    image1: "/assets/humanitarian/images/mission1a.png",
    image2: "/assets/humanitarian/images/mission1b.png"
  },
  {
    key: "mission-2",
    ru: {
      title: "INSO — безопасность и доступ",
      place: "Уагадугу / Бамако / Ниамей",
      type: "безопасность / инциденты / доступ / маршруты",
      interest: "Картирование инцидентов, доступ, маршруты, анализ безопасности",
      note: "ГИС, QGIS, анализ данных, картирование инцидентов, базовый Python, английский.",
      img1: "Кластеры насилия в центральном Мали (регион Мопти). Пространственная концентрация инцидентов указывает на устойчивые зоны нестабильности. Источник: ACLED",
      img2: "Распределение политического насилия в Западной Африке. Высокая плотность событий формирует зоны повышенного риска и ключевые коридоры нестабильности. Источник: ACLED"
    },
    en: {
      title: "INSO — security and access",
      place: "Ouagadougou / Bamako / Niamey",
      type: "security / incidents / access / routes",
      interest: "Incident mapping, access constraints, route analysis, security context",
      note: "GIS, QGIS, data analysis, mapping incidents, basic Python, English.",
      img1: "Violence clusters in central Mali (Mopti region). Spatial concentration of events highlights persistent insecurity zones. Source: ACLED",
      img2: "Distribution of political violence in West Africa. High event density reveals risk zones and key instability corridors across the region. Source: ACLED"
    },
    fr: {
