---
import SiteLayout from "../layouts/SiteLayout.astro";

const pageTranslations = {
  ru: {
    title: "Обо мне",
    subtitle: "Биогеография, GIS и работа в Африке"
  },
  en: {
    title: "About",
    subtitle: "Biogeography, GIS and Africa focus"
  },
  fr: {
    title: "À propos",
    subtitle: "Biogéographie, SIG et travail en Afrique"
  }
};

const content = {
  ru: {
    sections: [
      {
        title: "МГУ им. М. В. Ломоносова",
        text: "Экология и природопользование, кафедра биогеографии географического ф-та. Тема диплома: \"Редкие растительные сообщества Алтае-Саянского оробиома\""
      },
      {
        title: "Лукойл-Пермь",
        text: "Диспетчер ПУ / Начальник ОПС. Сентябрь 2024 - Апрель 2026. Контроль за фондом скважин, координация производственных процессов."
      }
    ],
    galleryTitles: ["Вечная мерзлота, NCSCDv2", "Какао-бобы, ESG-риск", "Топография света, VIIRS data", "LTE в Африке, opencellid"],
    docsTitle: "Портфолио",
    docsOpen: "Открыть PDF",
    notesTitle: "Заметки",
    notes: [
      "Готов к переезду",
      "Зона интересов 12°-18° N; 15° W - 10° E, Дакар - Бамако - Уагадугу - Ниамей",
      "Предпочтение работе в поле"
    ],
    booksTitle: "Любимые книги",
    booksOpen: "Открыть файл",
    books: [
      {
        title: "QGIS Training Manual",
        file: "/assets/about/books/qgis-training-manual.pdf"
      },
      {
        title: "GDAL Documentation",
        file: "/assets/about/books/gdal-reference.pdf"
      },
      {
        title: "Remote Sensing Notes",
        file: "/assets/about/books/remote-sensing-notes.pdf"
      }
    ]
  },
  en: {
    sections: [
      {
        title: "Lomonosov Moscow State University",
        text: "Ecology and Environmental Management, Department of Biogeography, Faculty of Geography. Thesis: \"Rare Plant Communities of the Altai–Sayan Orobiome\""
      },
      {
        title: "Lukoil-Perm",
        text: "Control Room Dispatcher (Sep 2024 – Apr 2026). Monitoring well stock, coordinating production processes"
      }
    ],
    galleryTitles: ["Permafrost, NCSCDv2", "Deforestation and ESG-risk", "Thopography of Human Light, VIIRS data", "Africa LTE, OenCellID data"],
    docsTitle: "Portfolio",
    docsOpen: "Open PDF",
    notesTitle: "Notes",
    notes: [
      "Ready to relocate",
      "Area of interest: 12°–18° N; 15° W – 10° E (Dakar – Bamako – Ouagadougou – Niamey)",
      "Preference for field work"
    ],
    booksTitle: "Favourite books",
    booksOpen: "Open file",
    books: [
      {
        title: "QGIS Training Manual",
        file: "/assets/about/books/qgis-training-manual.pdf"
      },
      {
        title: "GDAL Documentation",
        file: "/assets/about/books/gdal-reference.pdf"
      },
      {
        title: "Remote Sensing Notes",
        file: "/assets/about/books/remote-sensing-notes.pdf"
      }
    ]
  },
  fr: {
    sections: [
      {
        title: "Université d’État de Moscou Lomonossov",
        text: "Écologie et gestion de l’environnement, département de biogéographie, faculté de géographie. Sujet de mémoire: \"Communautés végétales rares de l’orobiome Altaï-Sayan\""
      },
      {
        title: "Lukoil-Perm",
        text: "Dispatcher (septembre 2024 – avril 2026). Suivi du parc de puits, coordination des processus de production"
      }
    ],
    galleryTitles: ["Permafrost, NCSCDv2", "Deforestation and ESG-risk", "Thopography of Human Light, VIIRS data", "Africa LTE, OenCellID data"],
    docsTitle: "Portfolio",
    docsOpen: "Ouvrir le PDF",
    notesTitle: "Remarques",
    notes: [
      "Prêt à se relocaliser",
      "Zone d’intérêt : 12°–18° N ; 15° O – 10° E. Dakar – Bamako – Ouagadougou – Niamey",
      "Préférence pour le travail de terrain"
    ],
    booksTitle: "Livres préférés",
    booksOpen: "Ouvrir le fichier",
    books: [
      {
        title: "QGIS Training Manual",
        file: "/assets/about/books/qgis-training-manual.pdf"
      },
      {
        title: "GDAL Documentation",
        file: "/assets/about/books/gdal-reference.pdf"
      },
      {
        title: "Remote Sensing Notes",
        file: "/assets/about/books/remote-sensing-notes.pdf"
      }
    ]
  }
};

const gallery = [
  {
    src: "/assets/about/images/portfolio.png"
  },
  {
    src: "/assets/about/images/portfolio2.png"
  },
  {
    src: "/assets/about/images/portfolio3.png"
  },
  {
    src: "/assets/about/images/portfolio4.png"
  }
];

const docs = [
  {
    file: "/assets/about/docs/cv.pdf"
  }
];
---

<SiteLayout pageTranslations={pageTranslations}>
  <style>
    .about-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 18px;
      margin-top: 24px;
    }

    .about-card {
      background: rgba(255, 255, 255, 0.96);
      border: 1px solid #d9e1ea;
      border-radius: 16px;
      padding: 20px;
      box-shadow: 0 8px 20px rgba(40, 60, 90, 0.05);
    }

    .about-card h2,
    .about-card h3 {
      margin-top: 0;
      color: #1d3d67;
    }

    .about-card p {
      margin-bottom: 0;
      line-height: 1.75;
      color: #425b78;
    }

    .gallery-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 18px;
      margin-top: 24px;
    }

    .gallery-card {
      background: white;
      border: 1px solid #dde5ed;
      border-radius: 16px;
      overflow: hidden;
      box-shadow: 0 8px 20px rgba(40, 60, 90, 0.05);
    }

    .gallery-card img {
      width: 100%;
      display: block;
      aspect-ratio: 16 / 10;
      object-fit: cover;
    }

    .gallery-caption {
      padding: 12px 14px;
      color: #5d6f86;
      font-size: 14px;
    }

    .gallery-caption a {
      color: #174b87;
      font-weight: 600;
      text-decoration: none;
    }

    .docs-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 18px;
      margin-top: 24px;
    }

    .doc-card {
      background: rgba(255, 255, 255, 0.96);
      border: 1px solid #d9e1ea;
      border-radius: 16px;
      padding: 20px;
      box-shadow: 0 8px 20px rgba(40, 60, 90, 0.05);
    }

    .doc-card h3 {
      margin-top: 0;
      margin-bottom: 10px;
      color: #1d3d67;
    }

    .doc-card a {
      color: #174b87;
      font-weight: 600;
      text-decoration: none;
    }

    .notes-block {
      margin-top: 24px;
      background: rgba(255, 255, 255, 0.96);
      border: 1px solid #d9e1ea;
      border-radius: 16px;
      padding: 20px;
      box-shadow: 0 8px 20px rgba(40, 60, 90, 0.05);
    }

    .notes-block h2 {
      margin-top: 0;
      color: #1d3d67;
    }

    .notes-block ul {
      margin: 0;
      padding-left: 18px;
      line-height: 1.8;
      color: #425b78;
    }

    .books-block {
  margin-top: 24px;
  background: rgba(255, 255, 255, 0.96);
  border: 1px solid #d9e1ea;
  border-radius: 16px;
  padding: 20px;
  box-shadow: 0 8px 20px rgba(40, 60, 90, 0.05);
}

    .books-block h2 {
  margin-top: 0;
  margin-bottom: 18px;
  color: #1d3d67;
}

    .books-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 18px;
}

    @media (max-width: 900px) {
      .books-grid {
        grid-template-columns: 1fr;
  }
}
  </style>

  <div class="about-grid">
    {content.ru.sections.map((section, index) => (
      <div class="about-card">
        <h2 id={`section-title-${index}`}>{section.title}</h2>
        <p id={`section-text-${index}`}>{section.text}</p>
      </div>
    ))}
  </div>

  <div class="gallery-grid">
    {gallery.map((item, index) => (
      <div class="gallery-card">
        <a href={item.src} target="_blank">
          <img src={item.src} alt={`about-image-${index + 1}`} />
        </a>
        <div class="gallery-caption">
          <a href={item.src} target="_blank" id={`gallery-title-${index}`}>
            {content.ru.galleryTitles[index]}
          </a>
        </div>
      </div>
    ))}
  </div>

  <div class="docs-grid">
    {docs.map((doc, index) => (
      <div class="doc-card">
        <h3 id={`doc-title-${index}`}>{content.ru.docsTitle}</h3>
        <a href={doc.file} target="_blank" id={`doc-open-${index}`}>
          {content.ru.docsOpen}
        </a>
      </div>
    ))}
  </div>

  <div class="notes-block">
    <h2 id="notes-title">{content.ru.notesTitle}</h2>
    <ul>
      {content.ru.notes.map((note, index) => (
        <li id={`note-${index}`}>{note}</li>
      ))}
    </ul>
  </div>

  <div class="books-block">
  <h2 id="books-title">{content.ru.booksTitle}</h2>

  <div class="books-grid">
    {content.ru.books.map((book, index) => (
      <div class="doc-card">
        <h3 id={`book-title-${index}`}>{book.title}</h3>
        <a href={book.file} target="_blank" id={`book-open-${index}`}>
          {content.ru.booksOpen}
        </a>
      </div>
    ))}
  </div>
</div>

  <script define:vars={{ content }}>
    function setAboutLang(lang) {
      const t = content[lang];
      if (!t) return;

      t.sections.forEach((section, index) => {
        const titleEl = document.getElementById(`section-title-${index}`);
        const textEl = document.getElementById(`section-text-${index}`);
        if (titleEl) titleEl.textContent = section.title;
        if (textEl) textEl.textContent = section.text;
      });

      t.galleryTitles.forEach((title, index) => {
        const el = document.getElementById(`gallery-title-${index}`);
        if (el) el.textContent = title;
      });

      document.querySelectorAll("[id^='doc-title-']").forEach((el) => {
        el.textContent = t.docsTitle;
      });

      document.querySelectorAll("[id^='doc-open-']").forEach((el) => {
        el.textContent = t.docsOpen;
      });

      const notesTitle = document.getElementById("notes-title");
      if (notesTitle) notesTitle.textContent = t.notesTitle;

      t.notes.forEach((note, index) => {
        const el = document.getElementById(`note-${index}`);
        if (el) el.textContent = note;
      });

      const booksTitle = document.getElementById("books-title");
      if (booksTitle) booksTitle.textContent = t.booksTitle;

      t.books.forEach((book, index) => {
        const titleEl = document.getElementById(`book-title-${index}`);
        const openEl = document.getElementById(`book-open-${index}`);

        if (titleEl) titleEl.textContent = book.title;
        if (openEl) openEl.textContent = t.booksOpen;
});
    }

    const savedLang = localStorage.getItem("lang") || "ru";
    setAboutLang(savedLang);

    window.addEventListener("languageChanged", (event) => {
      setAboutLang(event.detail.lang);
    });
  </script>
</SiteLayout>