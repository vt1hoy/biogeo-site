    ],
    maps: "Карты",
    pdf: "PDF",
    workflow: "Workflow",
    python: "Python / GeoPandas",
    pipelineTitle: "Full pipeline",
    pipelineIntro: "Полная последовательность скриптов по кейсу.",
    pdfOpen: "Открыть PDF",
    fileOpen: "Открыть файл",
    copy: "Копировать",
    copied: "Скопировано",
    imageTitles: [
      "Distance to nearest healthcare facility",
      "Simple healthcare access score"
    ],
    pdfTitles: ["Dakar Healthcare Access Proxy — Field Brief"],
    workflowItems: [
      {
        title: "Workflow 1 — nearest facility accessibility model",
        steps: [
          "Загрузка пешеходной уличной сети Дакара из OSM",
          "Извлечение медицинских объектов из OSM",
          "Обрезка WorldPop raster по зоне исследования",
          "Перевод population raster в сетку и агрегация до 300 м",
