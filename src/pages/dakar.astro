    codeTitle2: "Python — nearest healthcare accessibility",
    codeDesc1: "OSMnx → walk network → nodes / edges → GeoJSON",
    codeDesc2: "population grid → nearest facility → dist_m / access_score",
    codeLoadError: "Ошибка загрузки кода"
  },

  en: {
    introTitle: "Case",
    introText:
      "This case examines pedestrian access to healthcare infrastructure across urban Dakar. I built a working GIS pipeline based on OpenStreetMap, WorldPop, and Python to measure how unevenly access to the nearest healthcare facility is distributed across the city.",
    keyFindingsTitle: "Key results",
    keyFindings: [
      "Median distance to the nearest healthcare facility: ~1.05 km",
      "25% of populated cells are within 457 m of the nearest facility",
      "25% of populated cells are farther than 4.12 km",
      "The central urban fabric is better served than peripheral zones"
    ],
    maps: "Maps",
    pdf: "PDF",
    workflow: "Workflow",
    python: "Python / GeoPandas",
    pipelineTitle: "Full pipeline",
    pipelineIntro: "Complete script sequence used in this case.",
    pdfOpen: "Open PDF",
    fileOpen: "Open file",
    copy: "Copy",
    copied: "Copied",
    imageTitles: [
      "Distance to nearest healthcare facility",
      "Simple healthcare access score"
    ],
    pdfTitles: ["Dakar Healthcare Access Proxy — Field Brief"],
    workflowItems: [
      {
        title: "Workflow 1 — nearest facility accessibility model",
        steps: [
          "Download Dakar pedestrian street network from OSM",
          "Extract healthcare facilities from OSM",
          "Clip the WorldPop population raster to the study area",
          "Convert the population raster to a grid and aggregate to 300 m",
          "Calculate the distance from populated cells to the nearest facility",
          "Compute a simple access score",
          "Export the final GIS-ready layer"
        ]
      },
      {
        title: "Workflow 2 — urban mask and study area refinement",
        steps: [
          "Reproject the street network to a metric CRS",
          "Build a buffer around the street network",
          "Merge buffers into a single urban mask",
          "Clip the population grid to the actual urban area",
          "Recalculate distance-based accessibility",
          "Compare results before and after study area refinement"
        ]
      }
    ],
    pipelineLabels: [
      "1. Walk network",
      "2. Health facilities",
      "3. Clip population raster",
      "4. Population grid",
      "5. Population grid 300 m",
      "6. Health reprojection + capacity",
      "7. Urban mask",
      "8. Clip grid to urban mask",
      "9. Nearest accessibility"
    ],
    codeTitle1: "Python — walk network preprocessing",
    codeTitle2: "Python — nearest healthcare accessibility",
    codeDesc1: "OSMnx → walk network → nodes / edges → GeoJSON",
    codeDesc2: "population grid → nearest facility → dist_m / access_score",
    codeLoadError: "Code loading error"
  },

  fr: {
    introTitle: "Cas",
    introText:
      "Ce cas examine l'accessibilité piétonne à l'infrastructure de santé dans l'espace urbain de Dakar. J'ai construit un pipeline SIG fonctionnel à partir d'OpenStreetMap, de WorldPop et de Python afin de mesurer à quel point l'accès au service de santé le plus proche est inégalement réparti dans la ville.",
    keyFindingsTitle: "Résultats clés",
    keyFindings: [
      "Distance médiane au service de santé le plus proche : ~1.05 km",
      "25% des cellules peuplées se trouvent à moins de 457 m",
      "25% des cellules peuplées sont à plus de 4.12 km",
      "Le tissu urbain central est mieux desservi que les périphéries"
    ],
    maps: "Cartes",
    pdf: "PDF",
    workflow: "Workflow",
    python: "Python / GeoPandas",
    pipelineTitle: "Full pipeline",
    pipelineIntro: "Séquence complète des scripts utilisés dans ce cas.",
    pdfOpen: "Ouvrir le PDF",
    fileOpen: "Ouvrir le fichier",
    copy: "Copier",
    copied: "Copié",
    imageTitles: [
      "Distance jusqu'au service de santé le plus proche",
      "Score simple d'accessibilité aux soins"
    ],
    pdfTitles: ["Dakar Healthcare Access Proxy — Field Brief"],
    workflowItems: [
      {
        title: "Workflow 1 — nearest facility accessibility model",
        steps: [
          "Téléchargement du réseau piétonnier de Dakar depuis OSM",
          "Extraction des établissements de santé depuis OSM",
          "Découpage du raster WorldPop sur la zone d’étude",
          "Conversion du raster de population en grille et agrégation à 300 m",
          "Calcul de la distance entre les cellules peuplées et l’établissement le plus proche",
          "Calcul d’un score simple d’accessibilité",
          "Export de la couche SIG finale"
        ]
      },
      {
        title: "Workflow 2 — urban mask and study area refinement",
        steps: [
          "Reprojection du réseau viaire dans une projection métrique",
          "Création d’un buffer autour du réseau",
