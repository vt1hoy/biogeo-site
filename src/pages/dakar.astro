---
import SiteLayout2 from "../layouts/SiteLayout2.astro";

const pageTranslations = {
  ru: {
    title: "Дакар — урбанизм",
    subtitle:
      "Пилотный кейс по пешей доступности медицинской инфраструктуры в городской зоне Дакара на основе OSM, WorldPop и Python GIS workflow."
  },
  en: {
    title: "Dakar — urbanism",
    subtitle:
      "A pilot case on pedestrian access to healthcare infrastructure in urban Dakar based on OSM, WorldPop, and a Python GIS workflow."
  },
  fr: {
    title: "Dakar — urbanisme",
    subtitle:
      "Un cas pilote sur l'accessibilité piétonne à l'infrastructure de santé dans l'espace urbain de Dakar à partir d'OSM, WorldPop et d'un workflow SIG en Python."
  }
};

const images = [
  { src: "/assets/dakar/images/health_distance.png" },
  { src: "/assets/dakar/images/health_score.png" }
];

const pdfs = [
  { file: "/assets/dakar/pdf/dakar_health_access_brief.pdf" }
];

const pipelineFiles = [
  "/assets/dakar/code/dakar_walk_network.py",
  "/assets/dakar/code/dakar_health_osm.py",
  "/assets/dakar/code/clip_population.py",
  "/assets/dakar/code/population_grid.py",
  "/assets/dakar/code/population_grid_300m.py",
  "/assets/dakar/code/prepare_health_32628.py",
  "/assets/dakar/code/build_urban_mask.py",
  "/assets/dakar/code/clip_population_grid_to_mask.py",
  "/assets/dakar/code/accessibility_nearest.py"
];

