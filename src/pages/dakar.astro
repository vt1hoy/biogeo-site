          "Découpage de la grille de population à la zone urbaine réelle",
          "Recalcul de l’accessibilité basée sur la distance",
          "Comparaison des résultats avant et après l’affinement de la zone d’étude"
        ]
      }
    ],
    pipelineLabels: [
      "1. Walk network",
      "2. Health facilities",
      "3. Clip population raster",
      "4. Population grid",
      "5. Population grid 300 m",
      "6. Health reprojection + capacity",
      "7. Urban mask",
      "8. Clip grid to urban mask",
      "9. Nearest accessibility"
    ],
    codeTitle1: "Python — prétraitement du réseau piétonnier",
    codeTitle2: "Python — accessibilité au service de santé le plus proche",
    codeDesc1: "OSMnx → walk network → nodes / edges → GeoJSON",
    codeDesc2: "population grid → nearest facility → dist_m / access_score",
    codeLoadError: "Erreur de chargement du code"
  }
};
---

<SiteLayout2 pageTranslations={pageTranslations}>
  <style>
    .block {
      background: rgba(255, 255, 255, 0.96);
      padding: 24px;
      border-radius: 18px;
      margin-bottom: 20px;
      border: 1px solid #d9e1ea;
      box-shadow: 0 8px 20px rgba(40, 60, 90, 0.05);
    }

    .block h2 {
      margin-top: 0;
      margin-bottom: 16px;
      color: #1d3d67;
      font-size: 28px;
      letter-spacing: -0.02em;
    }

    .intro-text {
      color: #425b78;
      line-height: 1.72;
      font-size: 15px;
      margin-bottom: 16px;
      max-width: 950px;
    }

    .findings-title {
      color: #284a73;
      margin: 18px 0 10px;
      font-size: 18px;
    }

    .findings-list {
      margin: 0;
      padding-left: 18px;
      color: #425b78;
      line-height: 1.8;
    }

    .image-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
    }

    .image-card {
      background: #fff;
      border: 1px solid #dde5ed;
      border-radius: 14px;
      overflow: hidden;
    }

    .image-card img {
      width: 100%;
      display: block;
      aspect-ratio: 16 / 10;
      object-fit: cover;
    }

    .image-caption {
      padding: 12px 14px;
      font-size: 14px;
      color: #5d6f86;
    }

    .image-caption a {
      color: #174b87;
      font-weight: 600;
    }

    .pdf-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 16px;
    }

    .pdf-card {
      background: #fbfdff;
      border: 1px solid #e1e8f0;
      border-radius: 14px;
      padding: 18px;
    }

    .pdf-card h3 {
      margin: 0 0 10px;
      color: #284a73;
      font-size: 18px;
    }

    .pdf-card a {
      color: #174b87;
      font-weight: 600;
      font-size: 14px;
    }

    .workflow-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
    }

    .workflow-item {
      background: #fbfdff;
      border: 1px solid #e1e8f0;
      border-radius: 14px;
      padding: 18px;
    }

    .workflow-item h3 {
      margin: 0 0 10px;
      color: #284a73;
      font-size: 18px;
    }

    .workflow-item ul {
      margin: 0;
      padding-left: 18px;
      line-height: 1.7;
      color: #425b78;
    }

    .pipeline-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 16px;
    }

    .pipeline-card {
      background: #fbfdff;
      border: 1px solid #e1e8f0;
      border-radius: 14px;
      padding: 18px;
    }

    .pipeline-card h3 {
      margin: 0 0 10px;
      color: #284a73;
      font-size: 16px;
      line-height: 1.45;
    }

    .pipeline-card a {
      color: #174b87;
      font-weight: 600;
      font-size: 14px;
    }

    .code-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 18px;
    }

    .code-card {
      background: #fbfdff;
      border: 1px solid #e1e8f0;
      border-radius: 14px;
      padding: 18px;
    }

    .code-card h3 {
      margin: 0 0 10px;
      color: #284a73;
    }

    .code-description {
      margin-bottom: 12px;
      color: #5b6d85;
      font-size: 14px;
      line-height: 1.6;
    }

    .code-top {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 12px;
      margin-bottom: 10px;
      flex-wrap: wrap;
    }

    .code-top a {
      color: #174b87;
      font-weight: 600;
      font-size: 14px;
    }

    .btn {
      background: #174b87;
      color: white;
      border: none;
      padding: 8px 14px;
      border-radius: 8px;
      cursor: pointer;
      font-size: 14px;
    }

    .btn:hover {
      opacity: 0.92;
    }

    .code-block {
      background: #0f1722;
      color: #d9e7ff;
      padding: 16px;
      border-radius: 12px;
      font-family: Consolas, monospace;
      white-space: pre;
      overflow: auto;
      line-height: 1.55;
      max-height: 420px;
      font-size: 13px;
      box-shadow: inset 0 0 0 1px rgba(255,255,255,0.04);
    }

    @media (max-width: 1100px) {
      .pipeline-grid {
        grid-template-columns: repeat(2, 1fr);
      }
    }

    @media (max-width: 900px) {
      .image-grid,
      .workflow-grid,
      .pipeline-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>

  <div class="block">
    <h2 id="intro-heading">{translations.ru.introTitle}</h2>
    <div class="intro-text" id="intro-text">{translations.ru.introText}</div>

    <h3 class="findings-title" id="findings-heading">
      {translations.ru.keyFindingsTitle}
    </h3>

    <ul class="findings-list" id="findings-list">
      {translations.ru.keyFindings.map((item) => (
        <li>{item}</li>
      ))}
    </ul>
  </div>

  <div class="block">
    <h2 id="maps-heading">{translations.ru.maps}</h2>

    <div class="image-grid">
      {images.map((item, index) => (
        <div class="image-card">
          <a href={item.src} target="_blank">
            <img src={item.src} alt={`dakar-image-${index + 1}`} />
          </a>
          <div class="image-caption">
            <a href={item.src} target="_blank" id={`image-title-${index}`}>
              {translations.ru.imageTitles[index]}
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>

  <div class="block">
    <h2 id="pdf-heading">{translations.ru.pdf}</h2>

    <div class="pdf-grid">
      {pdfs.map((pdf, index) => (
        <div class="pdf-card">
          <h3 id={`pdf-title-${index}`}>{translations.ru.pdfTitles[index]}</h3>
          <a href={pdf.file} target="_blank" class="pdf-open">
            {translations.ru.pdfOpen}
          </a>
        </div>
      ))}
    </div>
  </div>

  <div class="block">
    <h2 id="workflow-heading">{translations.ru.workflow}</h2>

    <div class="workflow-grid">
      {translations.ru.workflowItems.map((wf, wfIndex) => (
        <div class="workflow-item">
          <h3 id={`workflow-title-${wfIndex}`}>{wf.title}</h3>
          <ul id={`workflow-steps-${wfIndex}`}>
            {wf.steps.map((step) => (
              <li>{step}</li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>

  <div class="block">
    <h2 id="python-heading">{translations.ru.python}</h2>

    <div class="code-grid">
      <div class="code-card">
        <h3 id="code-title-1">{translations.ru.codeTitle1}</h3>

        <div class="code-description" id="code-desc-1">
          {translations.ru.codeDesc1}
        </div>

        <div class="code-top">
          <a href="/assets/dakar/code/dakar_walk_network.py" target="_blank" class="code-open">
            {translations.ru.fileOpen}
          </a>
          <button class="btn copy-btn" onclick="copyCode('code1', this)">
            {translations.ru.copy}
          </button>
        </div>

        <pre class="code-block" id="code1">Загрузка...</pre>
      </div>

      <div class="code-card">
        <h3 id="code-title-2">{translations.ru.codeTitle2}</h3>

        <div class="code-description" id="code-desc-2">
          {translations.ru.codeDesc2}
        </div>

        <div class="code-top">
          <a href="/assets/dakar/code/accessibility_nearest.py" target="_blank" class="code-open">
            {translations.ru.fileOpen}
          </a>
          <button class="btn copy-btn" onclick="copyCode('code2', this)">
            {translations.ru.copy}
          </button>
        </div>

        <pre class="code-block" id="code2">Загрузка...</pre>
      </div>
    </div>
  </div>

  <div class="block">
    <h2 id="pipeline-heading">{translations.ru.pipelineTitle}</h2>
    <div class="intro-text" id="pipeline-intro">{translations.ru.pipelineIntro}</div>

    <div class="pipeline-grid">
      {pipelineFiles.map((file, index) => (
        <div class="pipeline-card">
          <h3 id={`pipeline-label-${index}`}>{translations.ru.pipelineLabels[index]}</h3>
          <a href={file} target="_blank" class="code-open">
            {translations.ru.fileOpen}
          </a>
        </div>
      ))}
    </div>
  </div>

  <script define:vars={{ translations }}>
    const i18n = translations;

    function renderWorkflowItems(t) {
      t.workflowItems.forEach((wf, wfIndex) => {
        const titleEl = document.getElementById(`workflow-title-${wfIndex}`);
        const stepsEl = document.getElementById(`workflow-steps-${wfIndex}`);

        if (titleEl) titleEl.textContent = wf.title;

        if (stepsEl) {
          stepsEl.innerHTML = "";
          wf.steps.forEach((step) => {
            const li = document.createElement("li");
            li.textContent = step;
            stepsEl.appendChild(li);
          });
        }
      });
    }

    function renderFindings(t) {
      const findingsEl = document.getElementById("findings-list");
      if (!findingsEl) return;

      findingsEl.innerHTML = "";
      t.keyFindings.forEach((item) => {
        const li = document.createElement("li");
        li.textContent = item;
        findingsEl.appendChild(li);
      });
    }

    function renderPipelineLabels(t) {
      t.pipelineLabels.forEach((label, index) => {
        const el = document.getElementById(`pipeline-label-${index}`);
        if (el) el.textContent = label;
      });
    }

    function setDakarLang(lang) {
      const t = i18n[lang];
      if (!t) return;

      document.getElementById("intro-heading").textContent = t.introTitle;
      document.getElementById("intro-text").textContent = t.introText;
      document.getElementById("findings-heading").textContent = t.keyFindingsTitle;
      document.getElementById("maps-heading").textContent = t.maps;
      document.getElementById("pdf-heading").textContent = t.pdf;
      document.getElementById("workflow-heading").textContent = t.workflow;
      document.getElementById("python-heading").textContent = t.python;
      document.getElementById("pipeline-heading").textContent = t.pipelineTitle;
      document.getElementById("pipeline-intro").textContent = t.pipelineIntro;

      renderFindings(t);
      renderWorkflowItems(t);
      renderPipelineLabels(t);

      t.imageTitles.forEach((title, index) => {
        const el = document.getElementById(`image-title-${index}`);
        if (el) el.textContent = title;
      });

      t.pdfTitles.forEach((title, index) => {
        const el = document.getElementById(`pdf-title-${index}`);
        if (el) el.textContent = title;
      });

      document.getElementById("code-title-1").textContent = t.codeTitle1;
      document.getElementById("code-title-2").textContent = t.codeTitle2;
      document.getElementById("code-desc-1").textContent = t.codeDesc1;
      document.getElementById("code-desc-2").textContent = t.codeDesc2;

      document.querySelectorAll(".pdf-open").forEach((el) => {
        el.textContent = t.pdfOpen;
      });

      document.querySelectorAll(".code-open").forEach((el) => {
        el.textContent = t.fileOpen;
      });

      document.querySelectorAll(".copy-btn").forEach((el) => {
        el.textContent = t.copy;
        el.dataset.copyLabel = t.copy;
        el.dataset.copiedLabel = t.copied;
      });
    }

    async function loadCode(id, path) {
      const el = document.getElementById(id);
      try {
        const res = await fetch(path);
        if (!res.ok) throw new Error("fetch failed");
        const text = await res.text();
        el.textContent = text;
      } catch {
        const savedLang = localStorage.getItem("lang") || "ru";
        el.textContent = i18n[savedLang].codeLoadError;
      }
    }

    window.copyCode = function (id, btn) {
      const text = document.getElementById(id).textContent;
      navigator.clipboard.writeText(text);

      const copiedLabel = btn.dataset.copiedLabel || "Скопировано";
      const copyLabel = btn.dataset.copyLabel || "Копировать";

      btn.textContent = copiedLabel;
      setTimeout(() => {
        btn.textContent = copyLabel;
      }, 1200);
    };

    const savedLang = localStorage.getItem("lang") || "ru";
    setDakarLang(savedLang);

    window.addEventListener("languageChanged", (event) => {
      setDakarLang(event.detail.lang);
    });

    loadCode("code1", "/assets/dakar/code/dakar_walk_network.py");
    loadCode("code2", "/assets/dakar/code/accessibility_nearest.py");
  </script>
</SiteLayout2>