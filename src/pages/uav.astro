---
import SiteLayout2 from "../layouts/SiteLayout2.astro";

const pageTranslations = {
  ru: { title: "БПЛА — MAVLink", subtitle: "Подключение к SITL и работа через MAVLink" },
  en: { title: "UAV — MAVLink", subtitle: "SITL connection and MAVLink interaction" },
  fr: { title: "UAV — MAVLink", subtitle: "Connexion SITL et MAVLink" }
};

const translations = {
  ru: {
    caseLabel: "Кейс",
    caseIntro: "Подключение к SITL, отправка команд и попытка получить телеметрию.",
    caseResultsTitle: "Что сделано",
    caseResults: [
      "Поднят SITL",
      "Подключение MAVLink",
      "Команды отправлены",
      "Попытка навигации",
      "Чтение телеметрии"
    ],
    python: "Python / MAVLink",
    codeTitle1: "MAVLink — mission control",
    codeDesc1: "Подключение и команды",
    codeTitle2: "SITL / WSL setup",
    codeDesc2: "Установка SITL",
    fileOpen: "Открыть файл",
    copy: "Копировать",
    copied: "Скопировано"
  },

  en: {
    caseLabel: "Case",
    caseIntro: "SITL connection, command sending and telemetry reading.",
    caseResultsTitle: "What was done",
    caseResults: [
      "SITL deployed",
      "MAVLink connected",
      "Commands sent",
      "Waypoint attempt",
      "Telemetry read"
    ],
    python: "Python / MAVLink",
    codeTitle1: "MAVLink — mission control",
    codeDesc1: "Connection and commands",
    codeTitle2: "SITL / WSL setup",
    codeDesc2: "SITL setup",
    fileOpen: "Open file",
    copy: "Copy",
    copied: "Copied"
  },

  fr: {
    caseLabel: "Cas",
    caseIntro: "Connexion SITL, commandes et télémétrie.",
    caseResultsTitle: "Résultats",
    caseResults: [
      "SITL lancé",
      "Connexion MAVLink",
      "Commandes envoyées",
      "Navigation test",
      "Télémétrie"
    ],
    python: "Python / MAVLink",
    codeTitle1: "MAVLink — mission control",
    codeDesc1: "Connexion et commandes",
    codeTitle2: "SITL / WSL setup",
    codeDesc2: "Installation SITL",
    fileOpen: "Ouvrir le fichier",
    copy: "Copier",
    copied: "Copié"
  }
};
---

<SiteLayout2 pageTranslations={pageTranslations}>

<style>
.block {
  background: rgba(255,255,255,0.96);
  padding: 24px;
  border-radius: 18px;
  margin-bottom: 20px;
  border: 1px solid #d9e1ea;
  box-shadow: 0 8px 20px rgba(40,60,90,0.05);
}

.block h2 {
  margin: 0 0 16px;
  color: #1d3d67;
  font-size: 28px;
}

.block p {
  color: #425b78;
  font-size: 15px;
  line-height: 1.7;
  margin-bottom: 12px;
}

.block h3 {
  margin: 16px 0 8px;
  font-size: 18px;
  color: #284a73;
}

.block ul {
  margin: 0;
  padding-left: 18px;
  font-size: 14px;
  color: #425b78;
  line-height: 1.7;
}

.code-card {
  background: #fbfdff;
  border: 1px solid #e1e8f0;
  border-radius: 14px;
  padding: 18px;
  margin-bottom: 18px;
}

.code-description {
  margin-bottom: 10px;
  font-size: 14px;
  color: #5b6d85;
}

.code-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8px;
}

.code-open {
  color: #174b87;
  font-weight: 600;
  font-size: 14px;
  text-decoration: none !important;
}

.code-open:hover {
  text-decoration: underline;
}

.btn {
  background: #174b87;
  color: white;
  border: none;
  padding: 6px 12px;
  border-radius: 8px;
  cursor: pointer;
  font-size: 13px;
}

.code-block {
  background: #0f1722;
  color: #d9e7ff;
  padding: 14px;
  border-radius: 10px;
  font-family: Consolas, monospace;
  font-size: 12px;
  max-height: 260px;
  overflow: auto;
}
</style>

<div class="block">
  <h2 id="case-heading">{translations.ru.caseLabel}</h2>
  <p id="case-intro">{translations.ru.caseIntro}</p>

  <h3 id="case-results-title">{translations.ru.caseResultsTitle}</h3>
  <ul>
    {translations.ru.caseResults.map((item, i) => (
      <li id={`case-result-${i}`}>{item}</li>
    ))}
  </ul>
</div>

<div class="block">
  <h2 id="python-heading">{translations.ru.python}</h2>

  <div class="code-card">
    <h3 id="code-title-1">{translations.ru.codeTitle1}</h3>
    <div class="code-description" id="code-desc-1">{translations.ru.codeDesc1}</div>

    <div class="code-top">
      <a id="file-link-1" class="code-open" href="/assets/uav/code/mavlink_connect.py" target="_blank">
        {translations.ru.fileOpen}
      </a>
      <button class="btn copy-btn" onclick="copyCode('code1', this)">
        {translations.ru.copy}
      </button>
    </div>

    <pre class="code-block" id="code1">Загрузка...</pre>
  </div>

  <div class="code-card">
    <h3 id="code-title-2">{translations.ru.codeTitle2}</h3>
    <div class="code-description" id="code-desc-2">{translations.ru.codeDesc2}</div>

    <div class="code-top">
      <a id="file-link-2" class="code-open" href="/assets/uav/code/sitl_setup.txt" target="_blank">
        {translations.ru.fileOpen}
      </a>
      <button class="btn copy-btn" onclick="copyCode('code2', this)">
        {translations.ru.copy}
      </button>
    </div>

    <pre class="code-block" id="code2">Загрузка...</pre>
  </div>

</div>

<script define:vars={{ translations }}>
const i18n = translations;

function setLang(lang) {
  const t = i18n[lang];

  document.getElementById("case-heading").textContent = t.caseLabel;
  document.getElementById("case-intro").textContent = t.caseIntro;
  document.getElementById("case-results-title").textContent = t.caseResultsTitle;

  t.caseResults.forEach((item, i) => {
    document.getElementById(`case-result-${i}`).textContent = item;
  });

  document.getElementById("python-heading").textContent = t.python;
  document.getElementById("code-title-1").textContent = t.codeTitle1;
  document.getElementById("code-desc-1").textContent = t.codeDesc1;
  document.getElementById("code-title-2").textContent = t.codeTitle2;
  document.getElementById("code-desc-2").textContent = t.codeDesc2;

  document.getElementById("file-link-1").textContent = t.fileOpen;
  document.getElementById("file-link-2").textContent = t.fileOpen;

  document.querySelectorAll(".copy-btn").forEach(btn => {
    btn.textContent = t.copy;
    btn.dataset.copyLabel = t.copy;
    btn.dataset.copiedLabel = t.copied;
  });
}

async function loadCode(id, path) {
  const el = document.getElementById(id);
  try {
    const res = await fetch(path);
    el.textContent = await res.text();
  } catch {
    el.textContent = "error";
  }
}

window.copyCode = function(id, btn) {
  const text = document.getElementById(id).textContent;
  navigator.clipboard.writeText(text);
  btn.textContent = btn.dataset.copiedLabel;
  setTimeout(() => btn.textContent = btn.dataset.copyLabel, 1000);
};

const savedLang = localStorage.getItem("lang") || "ru";
setLang(savedLang);

window.addEventListener("languageChanged", e => {
  setLang(e.detail.lang);
});

loadCode("code1", "/assets/uav/code/mavlink_connect.py");
loadCode("code2", "/assets/uav/code/sitl_setup.txt");
</script>

</SiteLayout2>