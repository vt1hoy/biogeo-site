---

<SiteLayout pageTranslations={pageTranslations}>
  <style>
    .top-grid {
      display: grid;
      grid-template-columns: 1.15fr 1fr;
      gap: 20px;
      margin-top: 24px;
    }

    .card {
      background: rgba(255, 255, 255, 0.96);
      border: 1px solid #d9e1ea;
      border-radius: 18px;
      padding: 22px;
      box-shadow: 0 8px 20px rgba(40, 60, 90, 0.05);
    }

    .card h2 {
      margin-top: 0;
      margin-bottom: 14px;
      color: #1d3d67;
      font-size: 26px;
    }

    .card p,
    .card li {
      color: #425b78;
      line-height: 1.75;
    }

    .metrics-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 14px;
    }

    .metric-box {
      background: #fbfdff;
      border: 1px solid #e1e8f0;
      border-radius: 14px;
      padding: 16px;
    }

    .metric-label {
      margin: 0 0 8px;
      font-size: 13px;
      color: #5d6f86;
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }

    .metric-value {
      margin: 0;
      font-size: 20px;
      font-weight: 800;
      color: #1d3d67;
    }

    .section-block {
      margin-top: 24px;
    }

    .two-col {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
    }

    .list-block {
      margin: 0;
      padding-left: 18px;
    }

    .links-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
    }

    .link-card {
      background: #fbfdff;
      border: 1px solid #e1e8f0;
      border-radius: 14px;
      padding: 18px;
    }

    .link-card h3 {
      margin: 0 0 10px;
      color: #284a73;
      font-size: 18px;
    }

    .link-card a {
      color: #174b87;
      font-weight: 600;
      text-decoration: none;
    }

    @media (max-width: 980px) {
      .top-grid,
      .two-col,
      .links-grid,
      .metrics-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>

  <div class="top-grid">
    <div class="card">
      <h2 id="idea-title">{content.ru.ideaTitle}</h2>
      <ul class="list-block" id="idea-list">
        {content.ru.idea.map((item, index) => (
          <li id={`idea-${index}`}>{item}</li>
        ))}
      </ul>
    </div>

    <div class="card">
      <h2 id="metrics-title">{content.ru.metricsTitle}</h2>
      <div class="metrics-grid">
        {content.ru.metrics.map((item, index) => (
          <div class="metric-box">
            <p class="metric-label" id={`metric-label-${index}`}>{item.label}</p>
            <p class="metric-value" id={`metric-value-${index}`}>{item.value}</p>
          </div>
        ))}
      </div>
    </div>
  </div>

  <div class="section-block two-col">
    <div class="card">
      <h2 id="tokenomics-title">{content.ru.tokenomicsTitle}</h2>
      <ul class="list-block" id="tokenomics-list">
        {content.ru.tokenomics.map((item, index) => (
          <li id={`tokenomics-${index}`}>{item}</li>
        ))}
      </ul>
    </div>

    <div class="card">
      <h2 id="roadmap-title">{content.ru.roadmapTitle}</h2>
      <ul class="list-block" id="roadmap-list">
        {content.ru.roadmap.map((item, index) => (
          <li id={`roadmap-${index}`}>{item}</li>
        ))}
      </ul>
    </div>
  </div>

  <div class="section-block card">
    <h2 id="links-title">{content.ru.linksTitle}</h2>

    <div class="links-grid">
      {links.map((item, index) => (
        <div class="link-card">
          <h3>{item.label}</h3>
          <a href={item.href} target="_blank" id={`open-link-${index}`}>
            {content.ru.openLink}
          </a>
        </div>
      ))}
    </div>
  </div>

  <div class="section-block card">
    <h2 id="notes-title">{content.ru.notesTitle}</h2>
    <ul class="list-block">
      {content.ru.notes.map((item, index) => (
        <li id={`note-${index}`}>{item}</li>
      ))}
    </ul>
  </div>

  <script define:vars={{ content }}>
    function setBiogeoLang(lang) {
      const t = content[lang];
      if (!t) return;

      document.getElementById("idea-title").textContent = t.ideaTitle;
      document.getElementById("metrics-title").textContent = t.metricsTitle;
      document.getElementById("tokenomics-title").textContent = t.tokenomicsTitle;
      document.getElementById("links-title").textContent = t.linksTitle;
      document.getElementById("roadmap-title").textContent = t.roadmapTitle;
      document.getElementById("notes-title").textContent = t.notesTitle;

      t.idea.forEach((item, index) => {
        const el = document.getElementById(`idea-${index}`);
        if (el) el.textContent = item;
      });

      t.metrics.forEach((item, index) => {
        const labelEl = document.getElementById(`metric-label-${index}`);
        const valueEl = document.getElementById(`metric-value-${index}`);
        if (labelEl) labelEl.textContent = item.label;
        if (valueEl) valueEl.textContent = item.value;
      });

      t.tokenomics.forEach((item, index) => {
        const el = document.getElementById(`tokenomics-${index}`);
        if (el) el.textContent = item;
      });

      t.roadmap.forEach((item, index) => {
        const el = document.getElementById(`roadmap-${index}`);
        if (el) el.textContent = item;
      });

      t.notes.forEach((item, index) => {
        const el = document.getElementById(`note-${index}`);
        if (el) el.textContent = item;
      });

      document.querySelectorAll("[id^='open-link-']").forEach((el) => {
        el.textContent = t.openLink;
      });
    }

    const savedLang = localStorage.getItem("lang") || "ru";
    setBiogeoLang(savedLang);

    window.addEventListener("languageChanged", (event) => {
      setBiogeoLang(event.detail.lang);
    });
  </script>
</SiteLayout>